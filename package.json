{
  "name": "official-job-monitor",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Official-source opportunity monitoring for CS internships and new-grad roles.",
  "scripts": {
    "dev": "tsx scripts/dev-live.ts",
    "dev:live": "tsx scripts/dev-live.ts",
    "dev:sample": "npm run dev:services",
    "dev:services": "concurrently -k -n api,web -c yellow,cyan \"npm:dev:api\" \"npm:dev:web\"",
    "dev:services:live": "concurrently -k -n api,web -c yellow,cyan \"npm:dev:api:live\" \"npm:dev:web\"",
    "dev:api": "tsx watch src/server/index.ts",
    "dev:api:live": "tsx src/server/index.ts",
    "dev:web": "vite --host 127.0.0.1",
    "build": "npm run typecheck && vite build",
    "start": "tsx src/server/index.ts",
    "db:migrate": "tsx scripts/migrate.ts",
    "db:seed": "tsx scripts/seed.ts",
    "db:reset": "tsx scripts/reset-db.ts",
    "live:bootstrap": "tsx scripts/live-bootstrap.ts",
    "monitor:run": "tsx src/workers/run-monitor.ts",
    "monitor:live:preview": "tsx src/workers/run-monitor.ts --live --preview",
    "monitor:live": "tsx src/workers/run-monitor.ts --live",
    "worker:live": "tsx src/workers/run-live-worker.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "check": "npm run lint && npm run typecheck && npm run test && npm run build"
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "better-sqlite3": "12.11.1",
    "clsx": "2.1.1",
    "compression": "1.8.1",
    "express": "5.2.1",
    "express-rate-limit": "8.5.2",
    "helmet": "8.2.0",
    "lucide-react": "1.24.0",
    "pino": "10.3.1",
    "pino-http": "11.0.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-router-dom": "7.18.1",
    "tsx": "4.23.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/better-sqlite3": "7.6.13",
    "@types/compression": "1.8.1",
    "@types/express": "5.0.6",
    "@types/node": "26.1.1",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@types/supertest": "7.2.0",
    "@vitejs/plugin-react": "6.0.3",
    "concurrently": "10.0.3",
    "eslint": "10.6.0",
    "eslint-plugin-react-hooks": "7.1.1",
    "jsdom": "29.1.1",
    "supertest": "7.2.2",
    "typescript": "6.0.3",
    "typescript-eslint": "8.63.0",
    "vite": "8.1.4",
    "vitest": "4.1.10"
  }
}

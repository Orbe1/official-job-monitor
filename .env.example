# Optional local overrides. `npm run dev` works without an environment file.
NODE_ENV=development
PORT=8787
LOG_LEVEL=info
API_RATE_LIMIT_PER_MINUTE=240

# The sample and live workspaces intentionally use different SQLite files.
INTERNJOBS_DB_PATH=./data/internjobs.sqlite
INTERNJOBS_LIVE_DB_PATH=./data/internjobs.live.sqlite

# Local development identity. Production authentication is not implemented.
AUTH_MODE=development
DEV_USER_ID=user-local-dev

# Official-source monitoring. Only Cloudflare, Figma, and Databricks Greenhouse
# sources are enabled in the reviewed local catalog.
MONITOR_MODE=fixture
MONITOR_USER_AGENT=OfficialJobMonitor/0.1 (public-career-source monitor)
# Optional locally; required only when NODE_ENV=production. When provided it is
# sent in the HTTP User-Agent and is not stored in SQLite.
MONITOR_CONTACT_EMAIL=
MONITOR_TIMEOUT_MS=15000
MONITOR_MAX_RETRIES=2
MONITOR_CONCURRENCY=3
MONITOR_PER_HOST_CONCURRENCY=1
MONITOR_MIN_HOST_INTERVAL_MS=1000
